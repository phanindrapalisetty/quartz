# Copy to .env.prod and fill in all values before deploying.

# Google OAuth 
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# In production, traffic enters on port 80 via nginx — no :8000 in the callback URL.
# Add this exact URI to Google Cloud Console → Authorized redirect URIs.
GOOGLE_REDIRECT_URI=http://your-domain.com/auth/callback

# App URLs 
# Where the backend redirects the browser after a successful login.
FRONTEND_URL=http://your-domain.com

# Security 
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string
