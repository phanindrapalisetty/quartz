# Copy this to .env and fill in your values
# Get credentials at: https://console.cloud.google.com/ → APIs & Services → Credentials

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# OAuth callback — must match exactly what you set in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Where to redirect after login (your Streamlit URL)
STREAMLIT_URL=http://localhost:8501

# Server-side: Streamlit Python → FastAPI (Docker internal network)
API_URL=http://backend:8000
# Browser-side: login button and other links the user's browser navigates to
PUBLIC_API_URL=http://localhost:8000
